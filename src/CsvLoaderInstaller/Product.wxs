<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <!-- 
    SqlApiCli WiX Installer — Main Product Definition
    
    Scaffold: This file defines the product structure, directory layout, components, and features.
    Versioning is property-injected at build time from GitVersion by CI/CD.
    
    Build output: bin\Release\en-US\SqlApiCliInstaller.msi
  -->
  
  <Product
    Id="*"
    Name="SqlApiCli"
    Language="1033"
    Version="$(var.ProductVersion)"
    Manufacturer="BECOM Electronics GmbH"
    UpgradeCode="472F7B83-6787-4E4D-80EF-589CE863513F">

    <!-- Package metadata and installation scope -->
    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Description="SqlApiCli — IBM i SQL API CSV Export Tool" />

    <!-- Allow in-place upgrade of newer versions over older ones -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of SqlApiCli is already installed."
      AllowDowngrades="no"
      AllowSameVersionUpgrades="no" />

    <!-- Media: single CAB embedded in MSI -->
    <Media Id="1" Cabinet="SqlApiCli.cab" EmbedCab="yes" />

    <!-- Directory structure: TARGETDIR → ProgramFilesFolder → InstallFolder -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="SqlApiCli" />
      </Directory>
      
      <!-- Start Menu folder structure (will be used if shortcuts are enabled) -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="SqlApiCli" />
      </Directory>
    </Directory>

    <!-- Main product feature containing all components -->
    <Feature
      Id="SqlApiCliFeature"
      Title="SqlApiCli Installer"
      Level="1"
      Description="Installs SqlApiCli CLI tool with optional PATH integration and Start Menu shortcuts">

      <!-- Executable component -->
      <ComponentRef Id="SqlApiCliExecutable" />
      
      <!-- Registry entry for Add/Remove Programs discovery -->
      <ComponentRef Id="RegistryAddRemovePrograms" />
      
      <!-- Optional: Start Menu shortcuts (disabled by default in this scaffold) -->
      <ComponentRef Id="StartMenuShortcuts" />
      
      <!-- Optional: PATH environment variable integration (disabled by default in this scaffold) -->
      <ComponentRef Id="PathEnvironmentVariable" />
    </Feature>

    <!-- Component 1: SqlApiCli executable file -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="SqlApiCliExecutable" Guid="*" Win64="yes">
        <!-- 
          Source path uses $(var.PublishDir) injected at build time by CI/CD.
          CI/CD example: dotnet build -p:PublishDir=../SqlApiCli/bin/Release/net10.0/win-x64/publish
          File location: INSTALLFOLDER\SqlApiCli.exe
        -->
        <File
          Id="SqlApiCliExeFile"
          Source="$(var.PublishDir)\SqlApiCli.exe"
          KeyPath="yes"
          Checksum="yes" />
      </Component>
    </DirectoryRef>

    <!-- Component 2: Registry entries for Add/Remove Programs and product discovery -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="RegistryAddRemovePrograms" Guid="*" Win64="yes">
        <!-- 
          Registry path: HKEY_LOCAL_MACHINE\Software\Microsoft\Windows\CurrentVersion\Uninstall\SqlApiCli
          These entries make the product discoverable in Add/Remove Programs (Control Panel).
        -->
        <RegistryKey Root="HKLM" Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\SqlApiCli">
          <RegistryValue Type="string" Name="DisplayName" Value="SqlApiCli" />
          <RegistryValue Type="string" Name="DisplayVersion" Value="$(var.ProductVersion)" />
          <RegistryValue Type="string" Name="Publisher" Value="BECOM Electronics GmbH" />
          <RegistryValue Type="string" Name="InstallLocation" Value="[INSTALLFOLDER]" />
          <RegistryValue Type="string" Name="UninstallString" Value="msiexec.exe /x [ProductCode]" />
          <RegistryValue Type="string" Name="QuietUninstallString" Value="msiexec.exe /x [ProductCode] /quiet /norestart" />
          <RegistryValue Type="dword" Name="NoModify" Value="1" />
          <RegistryValue Type="dword" Name="NoRepair" Value="1" />
        </RegistryKey>

        <!-- 
          Optional: Additional registry entry for product version tracking (future use).
          Path: HKEY_LOCAL_MACHINE\Software\SqlApiCli
        -->
        <RegistryKey Root="HKLM" Key="Software\SqlApiCli">
          <RegistryValue Type="string" Name="InstallPath" Value="[INSTALLFOLDER]" KeyPath="yes" />
          <RegistryValue Type="string" Name="Version" Value="$(var.ProductVersion)" />
        </RegistryKey>
      </Component>
    </DirectoryRef>

    <!-- Component 3: Start Menu shortcuts (optional, user-selectable in v1.1+) -->
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcuts" Guid="*" Win64="yes">
        <!-- 
          Shortcut 1: "SqlApiCli Help" - runs SqlApiCli.exe with help flag
          This allows users to quickly view the help documentation from the Start Menu.
        -->
        <Shortcut
          Id="SqlApiCliHelpShortcut"
          Name="SqlApiCli Help"
          Target="[INSTALLFOLDER]SqlApiCli.exe"
          Arguments="--help"
          Description="Display SqlApiCli help and usage information" />

        <!-- 
          Shortcut 2: "Installation Folder" → opens the installation directory in Explorer
          Helps users access the executable directly.
        -->
        <Shortcut
          Id="InstallationFolderShortcut"
          Name="Installation Folder"
          Target="[INSTALLFOLDER]"
          Description="Open the SqlApiCli installation folder" />

        <!-- Remove the Start Menu folder on uninstall if empty -->
        <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
      </Component>
    </DirectoryRef>

    <!-- Component 4: PATH environment variable integration (optional, user-selectable in v1.1+) -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="PathEnvironmentVariable" Guid="*" Win64="yes">
        <!-- 
          EnvironmentVariable element manages system PATH modification.
          Action="set" with append="yes" adds INSTALLFOLDER to the end of PATH.
          This allows users to run "SqlApiCli" from any command prompt without the full path.
          
          Note: PATH modification requires elevated privileges (already granted by InstallScope="perMachine").
        -->
        <Environment
          Id="PATH"
          Name="PATH"
          Value="[INSTALLFOLDER]"
          Permanent="no"
          Part="last"
          Action="set"
          System="yes" />
      </Component>
    </DirectoryRef>

    <!-- Standard WiX UI: Minimal dialogs (welcome, setup type, ready, complete) -->
    <UI Id="WixUI_Minimal">
      <!-- 
        Use the standard WiX UI library with minimal dialogs.
        This scaffold uses the built-in WixUI_Minimal set (no custom dialogs).
        
        Future enhancement: WixUI_FeatureTree for more control over optional features.
      -->
      <UIRef Id="WixUI_Minimal" />
    </UI>

    <!-- License file reference for the WiX UI -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
  </Product>
</Wix>
